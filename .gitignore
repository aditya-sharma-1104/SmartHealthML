# ==============================================================================
# SmartHealthML — .gitignore
# ==============================================================================

# --- IDE / Editor ---
.vscode/
.idea/
*.swp
*.swo
*.suo
*.user
*.sublime-workspace
*.sublime-project

# --- OS Generated Files ---
.DS_Store
Thumbs.db
Desktop.ini
ehthumbs.db

# ==============================================================================
# Python / Backend
# ==============================================================================
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
*.pdb

# Virtual environments
Backend/.venv/
.venv/
env/
venv/
ENV/
.Python

# Distribution / packaging
dist/
build/
*.egg-info/
*.egg

# Unit test / coverage
.tox/
.coverage
.coverage.*
htmlcov/
.pytest_cache/
*.coveragerc

# Flask instance folder & database
Backend/instance/
Backend/smarthealth.db
instance/
*.sqlite3
*.db

# Environment variables / secrets  ← NEVER commit real .env files
.env
*.env
!.env.example
!Frontend/.env.example

# ==============================================================================
# Node.js / Frontend
# ==============================================================================
node_modules/
Frontend/node_modules/
Frontend/dist/
Frontend/.env
!Frontend/.env.example

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
Frontend/npm-debug.log*
Frontend/yarn-debug.log*
Frontend/yarn-error.log*

# Build outputs
dist/
.next/
.nuxt/
.output/

# ==============================================================================
# Machine Learning / Data
# ==============================================================================
# Ignore large CSVs but keep the sample
data/*.csv
!data/sample_data.csv

# Ignore extra model versions, keep the active ones
models/*.pkl
!models/outbreak_model_v5.pkl
!models/risk_label_encoder_v5.pkl

# Jupyter notebook checkpoints
.ipynb_checkpoints/
notebooks/.ipynb_checkpoints/

# ==============================================================================
# Logs & Misc
# ==============================================================================
*.log
logs/
*.bak
*.tmp
*.swp
scripts/__pycache__/

